/* ============================================
 * Dark Theme — WB亏损计算系统
 * Design: Material 3 Dark + VS Code Modern
 * Palette: Deep Surface + Indigo Accent
 * ============================================ */

/* ── Global ── */
QMainWindow {
    background: #1A1A1A;
}
QScrollArea,
QStackedWidget {
    background: #1A1A1A;
}
QScrollArea > QWidget > QWidget {
    background: #1A1A1A;
}
QWidget#syncGridContainer {
    background: #1A1A1A;
}
QWidget {
    font-family: "Segoe UI Variable", "Segoe UI", "Microsoft YaHei UI", sans-serif;
    font-size: 13px;
    color: #E4E1E6;
}

/* ── Buttons ── */
QPushButton {
    background: #2C2C2C;
    border: 1px solid #3A3A3A;
    border-radius: 8px;
    padding: 7px 22px;
    color: #A5B4FC;
    font-weight: 500;
    min-height: 34px;
    font-size: 13px;
}
QPushButton:hover {
    background: #363636;
    border-color: #4A4A4A;
}
QPushButton:pressed {
    background: #222;
    border-color: #A5B4FC;
}
QPushButton:disabled {
    background: #222;
    color: #555;
    border-color: #333;
}

/* Primary Button */
QPushButton[class="btn-primary"] {
    background: #4338CA;
    border: none;
    color: #FFFFFF;
    font-weight: 600;
    border-radius: 8px;
}
QPushButton[class="btn-primary"]:hover {
    background: #3730A3;
}
QPushButton[class="btn-primary"]:pressed {
    background: #312E81;
}
QPushButton[class="btn-primary"]:disabled {
    background: #1E1B4B;
    color: #5A6ABF;
}

/* Danger / Cancel Button */
QPushButton[class="btn-danger"] {
    background: #B91C1C;
    border: none;
    color: #FFFFFF;
    font-weight: 600;
    border-radius: 8px;
}
QPushButton[class="btn-danger"]:hover {
    background: #991B1B;
}

/* Success Button */
QPushButton[class="btn-success"] {
    background: #059669;
    border: none;
    color: #FFFFFF;
    font-weight: 600;
    border-radius: 8px;
}
QPushButton[class="btn-success"]:hover {
    background: #047857;
}
QPushButton[class="btn-success"]:pressed {
    background: #065F46;
}
QPushButton[class="btn-success"]:disabled {
    background: #2A2F36;
    color: #64748B;
}

QPushButton[class="btn-outline"] {
    background: #252525;
    border: 1px solid #475569;
    color: #C7D2FE;
    font-weight: 500;
    border-radius: 8px;
}
QPushButton[class="btn-outline"]:hover {
    background: #2E3440;
    border-color: #818CF8;
}

/* Icon Button */
QPushButton[class="btn-icon"] {
    background: transparent;
    border: none;
    padding: 6px 12px;
    min-height: 28px;
    border-radius: 8px;
}
QPushButton[class="btn-icon"]:hover {
    background: #363636;
}

/* ── Input Fields ── */
QLineEdit {
    border: 1.5px solid #3A3A3A;
    border-radius: 8px;
    padding: 9px 14px;
    background: #252525;
    color: #E4E1E6;
    selection-background-color: #312E81;
    font-size: 13px;
}
QLineEdit:focus {
    border-color: #A5B4FC;
}

QComboBox {
    border: 1.5px solid #3A3A3A;
    border-radius: 8px;
    padding: 7px 14px;
    background: #252525;
    color: #E4E1E6;
    min-height: 34px;
}
QComboBox:focus {
    border-color: #A5B4FC;
}
QComboBox::drop-down {
    border: none;
    width: 30px;
}
QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #999;
    margin-right: 10px;
}
QComboBox QAbstractItemView {
    border: 1px solid #3A3A3A;
    background: #252525;
    selection-background-color: #312E81;
    selection-color: #A5B4FC;
    outline: none;
    border-radius: 6px;
    padding: 4px;
}

QDoubleSpinBox, QSpinBox {
    border: 1.5px solid #3A3A3A;
    border-radius: 8px;
    padding: 7px 14px;
    background: #252525;
    color: #E4E1E6;
}
QDoubleSpinBox:focus, QSpinBox:focus {
    border-color: #A5B4FC;
}
QDoubleSpinBox::up-button, QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #3A3A3A;
    border-bottom: 1px solid #3A3A3A;
    border-top-right-radius: 7px;
    background: #2D2D2D;
}
QDoubleSpinBox::up-button:hover, QSpinBox::up-button:hover {
    background: #3B3B3B;
}
QDoubleSpinBox::down-button, QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 20px;
    border-left: 1px solid #3A3A3A;
    border-bottom-right-radius: 7px;
    background: #2D2D2D;
}
QDoubleSpinBox::down-button:hover, QSpinBox::down-button:hover {
    background: #3B3B3B;
}
QDoubleSpinBox::up-arrow, QSpinBox::up-arrow {
    width: 8px;
    height: 8px;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjQTVCOEZDIiBzdHJva2Utd2lkdGg9IjIuNSIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIj48cG9seWxpbmUgcG9pbnRzPSIxOCAxNSAxMiA5IDYgMTUiLz48L3N2Zz4=);
}
QDoubleSpinBox::down-arrow, QSpinBox::down-arrow {
    width: 8px;
    height: 8px;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjQTVCOEZDIiBzdHJva2Utd2lkdGg9IjIuNSIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIj48cG9seWxpbmUgcG9pbnRzPSI2IDkgMTIgMTUgMTggOSIvPjwvc3ZnPg==);
}

/* ── ComboBox — 现代下拉样式 ── */
QComboBox {
    border: 1.5px solid #3A3A3A;
    border-radius: 6px;
    padding: 4px 8px;
    background: #252525;
    color: #E4E1E6;
    min-height: 24px;
}
QComboBox:focus {
    border-color: #A5B4FC;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 20px;
    border: none;
}
QComboBox::down-arrow {
    width: 10px;
    height: 10px;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMCIgaGVpZ2h0PSIxMCIgdmlld0JveD0iMCAwIDI0IDI0IiBmaWxsPSJub25lIiBzdHJva2U9IiM5Q0EzQUYiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIj48cG9seWxpbmUgcG9pbnRzPSI2IDkgMTIgMTUgMTggOSIvPjwvc3ZnPg==);
}
QComboBox QAbstractItemView {
    border: 1px solid #3A3A3A;
    border-radius: 6px;
    background: #252525;
    color: #E4E1E6;
    selection-background-color: #312E81;
    selection-color: #E0E7FF;
    outline: none;
    padding: 4px;
}
QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding: 2px 8px;
}
QComboBox QAbstractItemView::item:hover {
    background: #1E1B4B;
}

/* ── Tables ── */
QTableView {
    background: #1A1A1A;
    alternate-background-color: #202020;
    gridline-color: #333;
    border: 1px solid #333;
    border-radius: 10px;
    selection-background-color: #312E81;
    selection-color: #E4E1E6;
    outline: none;
    font-size: 13px;
}
QTableView::item {
    padding: 8px 14px;
    border-bottom: 1px solid #252525;
}
QTableView::item:selected {
    background: #312E81;
}

QHeaderView::section {
    background: #202020;
    color: #999;
    font-weight: 600;
    font-size: 12px;
    padding: 12px 14px;
    border: none;
    border-bottom: 2px solid #333;
    border-right: 1px solid #333;
    letter-spacing: 0.3px;
}
QHeaderView::section:hover {
    background: #2A2A2A;
}

/* ── Group Boxes (Card Style) ── */
QGroupBox {
    border: 1px solid #333;
    border-radius: 14px;
    margin-top: 22px;
    padding: 24px 18px 18px 18px;
    font-weight: 600;
    font-size: 14px;
    background: #252525;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 18px;
    padding: 0 10px;
    color: #E4E1E6;
    background: #252525;
}

/* ── Splitter ── */
QSplitter::handle {
    background: #333;
}
QSplitter::handle:horizontal {
    width: 1px;
}
QSplitter::handle:vertical {
    height: 1px;
}
QSplitter::handle:hover {
    background: #A5B4FC;
}

/* ── Scrollbars ── */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #444;
    border-radius: 4px;
    min-height: 40px;
}
QScrollBar::handle:vertical:hover {
    background: #666;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background: #444;
    border-radius: 4px;
    min-width: 40px;
}
QScrollBar::handle:horizontal:hover {
    background: #666;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* ── Status Bar ── */
QStatusBar {
    background: #202020;
    border-top: 1px solid #333;
    color: #999;
    font-size: 12px;
    padding: 4px 14px;
}

/* ── Progress Bar ── */
QProgressBar {
    border: none;
    border-radius: 4px;
    background: #333;
    height: 6px;
    text-align: center;
}
QProgressBar::chunk {
    background: #A5B4FC;
    border-radius: 4px;
}

/* ── Tab Widget ── */
QTabWidget::pane {
    border: none;
    background: transparent;
}
QTabBar::tab {
    background: transparent;
    color: #999;
    padding: 10px 22px;
    border-bottom: 2px solid transparent;
    font-size: 13px;
}
QTabBar::tab:selected {
    color: #A5B4FC;
    border-bottom-color: #A5B4FC;
    font-weight: 600;
}
QTabBar::tab:hover:!selected {
    color: #A5B4FC;
}

/* ── Menu Bar ── */
QMenuBar {
    background: #202020;
    border-bottom: 1px solid #333;
    color: #CCC;
    font-size: 13px;
    padding: 2px 0;
}
QMenuBar::item {
    padding: 8px 16px;
    background: transparent;
    border-radius: 4px;
}
QMenuBar::item:selected {
    background: #312E81;
    color: #A5B4FC;
}
QMenu {
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 8px 0;
}
QMenu::item {
    padding: 8px 32px;
    color: #E4E1E6;
}
QMenu::item:selected {
    background: #312E81;
    color: #A5B4FC;
}
QMenu::separator {
    height: 1px;
    background: #333;
    margin: 4px 0;
}

/* ── Dialog ── */
QDialog {
    background: #252525;
}
QDialogButtonBox QPushButton {
    min-width: 88px;
    border-radius: 8px;
    padding: 8px 24px;
}

/* ── Tooltips ── */
QToolTip {
    background: #3A3A3A;
    color: #E4E1E6;
    border: none;
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 12px;
}

/* ── CheckBox — 现代圆角方形样式 ── */
QCheckBox {
    spacing: 8px;
    color: #E4E1E6;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #6B7280;
    background: #1F2937;
}
QCheckBox::indicator:hover {
    border-color: #A5B4FC;
}
QCheckBox::indicator:checked {
    background: #6366F1;
    border-color: #6366F1;
    image: url(data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxNCIgaGVpZ2h0PSIxNCIgdmlld0JveD0iMCAwIDI0IDI0IiBmaWxsPSJub25lIiBzdHJva2U9IndoaXRlIiBzdHJva2Utd2lkdGg9IjMiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCI+PHBvbHlsaW5lIHBvaW50cz0iMjAgNiA5IDE3IDQgMTIiLz48L3N2Zz4=);
}

/* ── Radio Buttons — 现代圆形样式 ── */
QRadioButton {
    spacing: 6px;
    color: #E4E1E6;
}
QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border-radius: 9px;
    border: 2px solid #6B7280;
    background: #1F2937;
}
QRadioButton::indicator:hover {
    border-color: #A5B4FC;
}
QRadioButton::indicator:checked {
    background: #1F2937;
    border-color: #6366F1;
    border-width: 6px;
}

/* ══════════════════════════════════════════════
 * Sidebar
 * ══════════════════════════════════════════════ */
QWidget#sidebar {
    background: #202020;
    border-right: 1px solid #333;
}

/* ══════════════════════════════════════════════
 * Top Bar
 * ══════════════════════════════════════════════ */
QWidget#topbar {
    background: #252525;
    border-bottom: 1px solid #333;
    min-height: 72px;
    max-height: 72px;
}

QLabel#pageTitle {
    font-size: 20px;
    font-weight: 700;
    color: #F9FAFB;
}

QLabel#pageSubtitle {
    font-size: 12px;
    color: #9CA3AF;
}

QLabel#contextBadge {
    background: #1E1B4B;
    color: #C7D2FE;
    border: 1px solid #3730A3;
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 11px;
    font-weight: 600;
}

QLabel#contextHint {
    font-size: 11px;
    color: #9CA3AF;
}

QLabel#exchangeRate {
    font-weight: 600;
    font-size: 13px;
    color: #E4E1E6;
}

QLabel#exchangeTimestamp {
    color: #777;
    font-size: 11px;
}

/* ── Stat Labels ── */
QLabel[class="stat-profit"] {
    color: #6EE7B7;
    font-weight: 600;
    font-size: 14px;
}
QLabel[class="stat-loss"] {
    color: #FCA5A5;
    font-weight: 600;
    font-size: 14px;
}
QLabel[class="stat-unmatched"] {
    color: #777;
    font-size: 13px;
}
QLabel[class="stat-total"] {
    font-weight: 600;
    font-size: 14px;
    color: #E4E1E6;
}
QLabel[class="stat-label"] {
    color: #777;
    font-size: 11px;
}

/* ── Result Table Header ── */
QTableView#resultTable {
    border: 1px solid #333;
    border-radius: 10px;
}
QTableView#resultTable QHeaderView::section {
    background: #202020;
    color: #999;
    font-weight: 600;
    font-size: 12px;
    padding: 12px 14px;
    border: 1px solid #333;
    letter-spacing: 0.3px;
}

/* ── Thumbnail Placeholder ── */
QLabel[class="thumbnail-placeholder"] {
    background: #252525;
    border: 1px dashed #444;
    border-radius: 8px;
    color: #555;
    font-size: 10px;
}

/* ══════════════════════════════════════════════
 * Data Card (legacy)
 * ══════════════════════════════════════════════ */
QWidget#dataCard {
    background: #252525;
    border: 1px solid #333;
    border-radius: 14px;
}
QWidget#dataCard QLabel {
    background: transparent;
    border: none;
}
QWidget#dataCard QLabel#cardTitle {
    color: #E4E1E6;
    font-size: 14px;
    font-weight: bold;
}
QWidget#dataCard QFrame#cardSep {
    background: #3A3A3A;
    border: none;
    max-height: 1px;
}

/* ══════════════════════════════════════════════
 * Module Card V2 — 分类 accent 色卡片
 * ══════════════════════════════════════════════ */
QWidget#moduleCard {
    background: #2A2A2E;
    border: 1.5px solid #404040;
    border-bottom: 3px solid #555555;
    border-radius: 16px;
    min-height: 60px;
}
QWidget#moduleCard QLabel {
    background: transparent;
    border: none;
}
QWidget#moduleCard QLabel#moduleIcon {
    font-size: 20px;
    color: #E4E1E6;
}
QWidget#moduleCard QLabel#moduleTitle {
    color: #E4E1E6;
    font-size: 15px;
    font-weight: bold;
}
QWidget#moduleCard QLabel#moduleVersion {
    color: #6B7280;
    font-size: 11px;
}
QWidget#moduleCard QLabel#moduleDesc {
    color: #999;
    font-size: 11px;
}

/* ── Accent 分割线（2px，按分类着色） ── */
QFrame#moduleAccentSep {
    border: none;
    max-height: 2px;
    border-radius: 1px;
}

/* ── Blue accent: 飞书 ── */
QWidget#moduleCard[accent="blue"] {
    border-bottom-color: #4338CA;
}
QWidget#moduleCard[accent="blue"]:hover {
    border-color: #4338CA;
    border-bottom-color: #6366F1;
    background: #303036;
}
QWidget#moduleCard[accent="blue"] QFrame#moduleAccentSep {
    background: #4338CA;
}
QWidget#moduleCard[accent="blue"] QLabel#moduleIcon {
    color: #A5B4FC;
}

/* ── Green accent: 佣金 ── */
QWidget#moduleCard[accent="green"] {
    border-bottom-color: #059669;
}
QWidget#moduleCard[accent="green"]:hover {
    border-color: #059669;
    border-bottom-color: #34D399;
    background: #303036;
}
QWidget#moduleCard[accent="green"] QFrame#moduleAccentSep {
    background: #059669;
}
QWidget#moduleCard[accent="green"] QLabel#moduleIcon {
    color: #6EE7B7;
}

/* ── Orange accent: 汇率 ── */
QWidget#moduleCard[accent="orange"] {
    border-bottom-color: #D97706;
}
QWidget#moduleCard[accent="orange"]:hover {
    border-color: #D97706;
    border-bottom-color: #FBBF24;
    background: #303036;
}
QWidget#moduleCard[accent="orange"] QFrame#moduleAccentSep {
    background: #D97706;
}
QWidget#moduleCard[accent="orange"] QLabel#moduleIcon {
    color: #FCD34D;
}

/* ── Legacy (for old moduleSep) ── */
QWidget#moduleCard QFrame#moduleSep {
    background: #3A3A3A;
    border: none;
    max-height: 1px;
}

/* ── Module Card Remove Button ── */
QPushButton#moduleRemoveBtn {
    background: transparent;
    border: none;
    color: #555;
    font-size: 16px;
    font-weight: bold;
    border-radius: 12px;
    padding: 0px;
    min-height: 24px;
    min-width: 24px;
}
QPushButton#moduleRemoveBtn:hover {
    background: #5C2020;
    color: #FCA5A5;
}
QPushButton#moduleRemoveBtn:pressed {
    background: #7A2020;
    color: #EF9A9A;
}

/* ── Manage Interface Button ── */
QPushButton#btnAddInterface {
    background: #202020;
    border: 2px dashed #3A3A3A;
    border-radius: 14px;
    color: #999;
    font-size: 14px;
    font-weight: 500;
}
QPushButton#btnAddInterface:hover {
    background: #2A2A30;
    border-color: #A5B4FC;
    color: #A5B4FC;
}
QPushButton#btnAddInterface:pressed {
    background: #312E81;
    border-color: #A5B4FC;
    color: #A5B4FC;
}

/* ── Feishu Info Box (Blue) ── */
QFrame#feishuInfoBox {
    background: #1E1B4B;
    border: 1px solid #312E81;
    border-radius: 10px;
}
QFrame#feishuInfoBox QLabel {
    background: transparent;
    border: none;
}

/* ── Commission Info Box (Green) ── */
QFrame#commissionInfoBox {
    background: #052E16;
    border: 1px solid #065F46;
    border-radius: 10px;
}
QFrame#commissionInfoBox QLabel {
    background: transparent;
    border: none;
}

/* ── Rate Box / Exchange Rate Info (Orange) ── */
QFrame#rateBox {
    background: #422006;
    border: 1px solid #92400E;
    border-radius: 10px;
}
QFrame#rateBox QLabel {
    background: transparent;
    border: none;
}
QLabel#rateValue {
    font-size: 24px;
    font-weight: bold;
    color: #FCD34D;
}
QLabel#rateHint {
    font-size: 11px;
    color: #D4D4D4;
}

/* ── Settings Page Card ── */
QGroupBox#settingsCard {
    background: #252525;
    border: 1px solid #333;
    border-radius: 14px;
    margin-top: 0px;
    padding: 22px 18px 18px 18px;
}
QGroupBox#settingsCard::title {
    subcontrol-origin: border;
    subcontrol-position: top center;
    padding: 4px 18px;
    color: #E4E1E6;
    background: #252525;
    font-weight: bold;
    font-size: 14px;
}

/* ── Mini Button (高级设置内小按钮) ── */
QPushButton[class="mini-btn"] {
    font-size: 12px;
    padding: 0;
    border: 1px solid #4B5563;
    border-radius: 3px;
    background: transparent;
    color: #9CA3AF;
    min-height: 20px;
}
QPushButton[class="mini-btn"]:hover {
    background: #374151;
    color: #E5E7EB;
}

/* ── Cell View Button (表格内查看按钮，必须覆盖全局QPushButton样式) ── */
QPushButton#cellViewBtn {
    font-size: 11px;
    padding: 1px 4px;
    border: 1px solid #6366F1;
    border-radius: 3px;
    background: #1E1B4B;
    color: #A5B4FC;
    min-height: 0px;
    max-height: 18px;
    min-width: 0px;
    max-width: 40px;
}
QPushButton#cellViewBtn:hover {
    background: #312E81;
    border-color: #818CF8;
}

/* ── Column Header Label (列映射表头) ── */
QLabel[class="col-header"] {
    font-weight: bold;
    color: #9CA3AF;
    background: transparent;
}

/* ── Column Separator Line ── */
QFrame#colSep {
    color: #374151;
    background: #374151;
    max-height: 1px;
    border: none;
}

/* ── Discount Dashboard ── */
QFrame#summaryCard {
    background: #252525;
    border: 1px solid #3A3A3A;
    border-radius: 8px;
}

QLabel#summaryCardTitle {
    font-size: 11px;
    color: #9CA3AF;
}

QLabel#summaryCardValue {
    font-size: 18px;
    font-weight: 700;
    color: #F9FAFB;
}

QLabel#summaryCardHint {
    font-size: 11px;
    color: #9CA3AF;
}

QGroupBox#workflowCard {
    border: 1px solid #3A3A3A;
    border-radius: 8px;
    background: #252525;
}

QLabel#workflowTitle {
    font-size: 15px;
    font-weight: 700;
    color: #F9FAFB;
}

QLabel#workflowHint {
    font-size: 12px;
    color: #9CA3AF;
}

QLabel#workflowBadges {
    font-size: 11px;
    color: #9CA3AF;
    padding: 2px 0 6px 0;
}

QLabel#fileSummary {
    font-size: 12px;
    color: #CBD5E1;
}

QFrame#calcControlGrid,
QFrame#filterBar {
    background: #202020;
    border: 1px solid #334155;
    border-radius: 8px;
}

QLabel#fieldLabel {
    font-size: 11px;
    color: #94A3B8;
    font-weight: 600;
}
